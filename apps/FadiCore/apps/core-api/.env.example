# Copy to .env for local development. Never commit real secrets.

NODE_ENV=development
PORT=8787

# Postgres (matches apps/FadiCore/docker-compose.yml)
DATABASE_URL=postgres://fadi:fadi@localhost:5433/fadi_core

# Session cookie
COOKIE_SECURE=false
COOKIE_DOMAIN=
SESSION_TTL_HOURS=12

# CORS origins (comma-separated). Admin :5180, RecipeAI :5173
CORS_ORIGIN=http://localhost:5180,http://localhost:5173

# Bootstrap owner (used only by db:seed)
# IMPORTANT: replace ADMIN_BOOTSTRAP_PASSWORD with a unique local value.
# Seed refuses the example password below.
ADMIN_BOOTSTRAP_EMAIL=fadi.admin@fadi.local
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe_Owner_2026!

# Login rate limit
LOGIN_RATE_MAX=5
LOGIN_RATE_WINDOW_MS=60000

# Phase 2 household invitations
INVITE_TTL_HOURS=168
# Phase 4 managed-member claim invitations
CLAIM_TTL_HOURS=168
# Phase 4b household join-request lifetime
JOIN_TTL_HOURS=168
# Adults may invite / manage minors only when true (owners always can)
ADULT_CAN_INVITE=false
